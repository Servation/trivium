# ── ONLINE MODE (cloud Supabase + OpenRouter for both LLM passes) ────────────
# Copy this file to .env.local and fill in your keys.
# For fully local/LAN play with LM Studio, see .env.local.offline.example.

# OpenRouter key -- covers BOTH passes. Get one at: https://openrouter.ai/keys
# Verify current model slugs + prices at: https://openrouter.ai/models
OPENROUTER_API_KEY=sk-or-...

# Pass 1 -- generation (cheap, fast). ~$0.09/$0.18 per 1M tokens.
GEN_MODEL=deepseek/deepseek-v4-flash
# GEN_BASE / GEN_KEY default to OpenRouter + OPENROUTER_API_KEY; only set to override.
# GEN_JSON_MODE=true   # enable only for models that support response_format: json_object

# Pass 2 -- verification / fact-check. Default = same cheap model.
# Quality lever: bump this to deepseek/deepseek-v4-pro, anthropic/claude-sonnet-4.6,
# or openai/gpt-5 when you want maximum trivia accuracy. (No other change needed.)
VERIFIER_MODEL=deepseek/deepseek-v4-flash
# VERIFIER_BASE / VERIFIER_KEY default to OpenRouter + OPENROUTER_API_KEY.

# Per-LLM-call timeout in ms (default 30000). A hung model rolls the lobby back
# instead of leaving everyone stuck on "Generating...". Raise it for big question
# counts on a slow model; lower it to fail faster.
# LLM_TIMEOUT_MS=30000

# Cache file path (defaults to quiz_cache.json in project root)
# Set to /tmp/quiz_cache.json on Vercel (only /tmp is writable there)
CACHE_FILE_PATH=quiz_cache.json

# Supabase (multiplayer) -- cloud project
# Get these from: Project Settings > Data API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key -- NEVER expose to the browser, server-side only
# Get from: Project Settings > Data API > service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...
