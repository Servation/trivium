# ── OFFLINE / LAN MODE (local Supabase + LM Studio for both passes) ──────────
# Requirements:
#   - LM Studio running at localhost:1234
#   - Docker Desktop installed
#   - Supabase CLI: npm install -g supabase && supabase start
#     (run once in the project folder; prints the URLs and keys below)
#
# Copy this file to .env.local and fill in the keys printed by "supabase start".

# Generation model (LM Studio -- OpenAI-compatible, default port 1234)
GEN_BASE=http://localhost:1234/v1
GEN_MODEL=local-model    # match the model name shown in LM Studio's server tab
GEN_KEY=lm-studio
# GEN_JSON_MODE stays off (default) -- LM Studio rejects response_format: json_object

# Verification model -- same LM Studio instance, second pass
VERIFIER_BASE=http://localhost:1234/v1
VERIFIER_MODEL=local-model
VERIFIER_KEY=lm-studio
# VERIFIER_JSON_MODE stays off (default) for the same reason

# Cache file path
CACHE_FILE_PATH=quiz_cache.json

# Supabase local (printed by "supabase start")
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key from supabase start>
SUPABASE_SERVICE_ROLE_KEY=<service_role key from supabase start>
